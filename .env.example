# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_KEY=<your-search-admin-key>
AZURE_SEARCH_INDEX=pubmedqa-index

# Azure OpenAI (embeddings + chat/judge)
AZURE_OPENAI_ENDPOINT=https://<your-openai-service>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-openai-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-54
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Foundry Project (for Agent Service + observability)
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-project>.cognitiveservices.azure.com

# Azure Cosmos DB (for AI judge results storage)
AZURE_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
AZURE_COSMOS_KEY=<your-cosmos-key>
AZURE_COSMOS_DATABASE=rag-feedback
AZURE_COSMOS_CONTAINER=judge-results

# Azure ML (for experiment tracking + DPO training)
AZURE_ML_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_ML_RESOURCE_GROUP=<your-resource-group>
AZURE_ML_WORKSPACE_NAME=<your-ml-workspace>

# Azure Blob Storage (for model checkpoints + LoRA adapters)
AZURE_STORAGE_CONNECTION_STRING=<your-storage-connection-string>
AZURE_STORAGE_CONTAINER=model-artifacts
